<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Application_Duration_Days__c</fullName>
    <description>Number of days since the application was created.</description>
    <externalId>false</externalId>
    <formula>IF(TR1__Reject__c = TRUE,(DATEVALUE(Application_Rejection_Date__c)-DATEVALUE(CreatedDate)),
   IF(ISNULL(Application_Completion_Date__c),(Today()-DATEVALUE(CreatedDate)),(DATEVALUE(Application_Completion_Date__c)-DATEVALUE(CreatedDate))
   )
)</formula>
    <inlineHelpText>Number of days since the application was created.</inlineHelpText>
    <label>Application Duration (Days)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
