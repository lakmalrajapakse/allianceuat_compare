<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>competency_and_bundle_type_mismatch</fullName>
    <active>true</active>
    <errorConditionFormula>(
  sirenum__Competency__r.Is_Role_Competency__c &amp;&amp;
  NOT(sirenum__CompetencyBundle__r.Is_Role_Bundle__c)
) ||
(
  NOT(sirenum__Competency__r.Is_Role_Competency__c) &amp;&amp;
  sirenum__CompetencyBundle__r.Is_Role_Bundle__c
)</errorConditionFormula>
    <errorMessage>Competencies can only be added to Bundles of the same type (role or skill).</errorMessage>
</ValidationRule>
