<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Session_Type__c</fullName>
    <description>Checks the session type based on the session name.</description>
    <externalId>false</externalId>
    <formula>IF(CONTAINS(LOWER(Name),&apos;interview&apos;),&apos;Interview&apos;,
IF(CONTAINS(LOWER(Name),&apos;induction&apos;),&apos;Induction&apos;,&apos;Other&apos;))</formula>
    <inlineHelpText>Checks the session type based on the session name.</inlineHelpText>
    <label>Session Type</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
