<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ValidationforRecordTypeupdate</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISNEW()),
    $Profile.Name = &apos;Alliance Connect User&apos;,
    ISCHANGED(RecordTypeId)
)</errorConditionFormula>
    <errorMessage>You can not update RecordType</errorMessage>
</ValidationRule>
