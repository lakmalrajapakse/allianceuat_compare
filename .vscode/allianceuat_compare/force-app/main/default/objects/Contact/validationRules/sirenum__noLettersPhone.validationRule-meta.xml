<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>sirenum__noLettersPhone</fullName>
    <active>true</active>
    <description>Phone number cannot contain letters</description>
    <errorConditionFormula>AND(NOT(ISBLANK(Phone)), NOT(REGEX(Phone, &quot;^([0-9+()-])[0-9 ()+-]+$&quot;)))</errorConditionFormula>
    <errorDisplayField>Phone</errorDisplayField>
    <errorMessage>Phone number cannot contain letters</errorMessage>
</ValidationRule>
