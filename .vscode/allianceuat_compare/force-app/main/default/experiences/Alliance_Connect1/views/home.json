      "componentAttributes" : {
        "richTextValue" : "<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\">If you don't have the <strong>Alliance Connect for Salesforce</strong> app, now is the time to download it.</p>\n<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\"><a href=\"https://play.google.com/store/apps/details?id=au.com.allianceaustralia.connect\" rel=\"noopener noreferrer\" target=\"_blank\"><img class=\"sfdcCbImage\" alt=\"\" src=\"{!contentAsset.sk_getitongoogleplay.1}\" style=\"width: 159.406px; height: 47.625px;\"></a></p>\n<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\"><a href=\"https://apps.apple.com/app/id6740983577\" rel=\"noopener noreferrer\" target=\"_blank\"><img class=\"sfdcCbImage\" alt=\"\" src=\"{!contentAsset.sk_availableonappstore.1}\" style=\"width: 163.312px; height: 48.4844px;\"></a></p>\n<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\">You're ready to add this Work Relationship to Connect.</p>\n<p style=\"text-align: center;\">Just tap the button, below, from your mobile or open the app and get started!</p>"
      },
      "componentName" : "forceCommunity:richTextInline",
