        "richTextValue" : "<p style=\"text-align: center;\">Need more help?</p><p style=\"text-align: center;\">Check out <a href=\"https://www.alliancenursing.com.au/mobile-app\" rel=\"noopener noreferrer\" target=\"_blank\">alliancenursing.com.au/mobile</a></p><p style=\"text-align: center;\"><span style=\"background-color: transparent;\">or drop a line to </span><a href=\"mailto:app.support@allianceaustralia.com.au\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"background-color: transparent;\">app.support@allianceaustralia.com.au</a></p>"
