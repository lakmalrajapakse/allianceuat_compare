<apex:page standardController="tc9_et__Invoice__c" extensions="NursingItemisedController" recordSetVar="tc9_et__Invoice__c" showHeader="false" renderAs="pdf" sidebar="false" applyBodyTag="false">
    <!-- renderAs="pdf" -->
    <head>
        <style>
            @page { 
                padding-top: 10px;
                size:A4 landscape;
                margin-top:3cm;
                margin-bottom:3cm;
                margin-right:1cm;
                margin-left:1cm;
                @top-center {
                    content: element(header);
                }
                @bottom-center {
                    content: element(footer);   
                }
            } 

            th, td, h2, h3, p{
                font-family: sans-serif;
            }

            div.header {
                display: block;
                position: running(header);
                padding-top:10pt;
            }
            div.footer {
                display: block;
                padding-top: 1pt;
                position: running(footer);
            }
            div.body {
                margin-left: -0.2cm;
                margin-right: -0.2cm;
            }

            .pagenumber:before {
                content: 'Page ' counter(page);
                font-size: 9pt;
                font-family: Sans-serif;
            }
            @media print {
                table { page-break-inside:auto }
                tr    { page-break-inside:avoid !important; page-break-after:auto; }
                thead { display:table-header-group; page-break-inside: avoid; overflow-hidden; }
                tfoot { display:table-footer-group; }
            
            tbody::after {
                content: ''; display: block;
                page-break-after: auto;
                page-break-inside: avoid;
                page-break-before: avoid;
                overflow:hidden;
            }
            }
            .page-break-inside-avoid {
                page-break-inside: avoid;
            }
            .displayNone {
                display: none;
            }
            .text-header {
                font-weight:bold; 
                font-size:12pt;
            }
            .text-body-bold {
                font-weight:bold; 
                font-size:10pt;
            }
            .text-body {
                font-size:10pt;
            }
            .text-table-data {
                font-size:9pt;
            } 
            .invoiceTable {
                -fs-table-paginate: paginate;
                border-collapse: collapse;
                border-spacing: 0;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .totalBtmLine td {
                border-bottom: 0.5pt solid #000000;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .totalTopLine td {
                border-bottom: 0.5pt solid #000000;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .totalBtmGreyLine td {
                border-bottom: 0.5pt solid #000000;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .totalBtmLightGreyLine  td {
                border-bottom: 0.5pt solid #e6e6e6;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .invoiceTable th {
                border-collapse: collapse;
                font-weight: bold;
                font-size:9pt;
                border-bottom: 1px solid #d3d3d3;
                padding-bottom: 2pt;
            }
            .invoiceTable td {
                vertical-align: top;
            }
            .invoiceTotalTable td,
            .invoiceTotalTable th {
                border-collapse: collapse;
                vertical-align: top;
                text-align: center;
                font-family: Sans-serif;
                font-size:9pt;
            }
            .subheaderContainer{
                page-break-inside: avoid;
                width: 100%;
            } 
            td{
                font-size: 9pt;
            } 
            table {
                font-family:Sans-serif
            }
            .invDetailTable {
                padding-top: 30pt;
            }
            .invoiceTotalTable {
                border-collapse: collapse;
                width: 50%;
                margin-left: 50%;
                margin-right: 5%;
                font-family: Sans-serif;
                page-break-inside: avoid !important;
                border :  solid 1px black;
                font-size:9pt;
            }
            .invHeading {
                font-size: 9pt;
                font-weight:bold;
                color:black;
                padding-right: 5pt;
            }
            .invTextJustify{
                text-align:right !important;
            }
            .backingSheetTable{
                border-collapse: collapse;
                width:100%; 
                padding-top : 4pt;
                margin-left: 0.5%;
                font-size:9pt;
                border: 1pt solid #D3D3D3;
            }
            .backingSheetTable td,
            .backingSheetTable th {
                border-top: 0.5pt solid black;
                border-collapse: collapse;
                padding-top: 4pt;
                padding-bottom: 4pt;
                vertical-align: top;
                text-align: center;
                font-family: Sans-serif;
                font-size:9pt;
                border: 0.2pt solid #D3D3D3;
                border-left: 0.2pt solid #D3D3D3;
                border-right: 0.2pt solid #D3D3D3;
            }
            .backingSheetTable th {
                font-family: Sans-serif;
                font-size:9pt;
            }
            .invAltRow {
                background-color:#D3D3D3;
            }
            table{
                page-break-inside: auto;
            }
            tr{
                page-break-inside: avoid;
            }
            hr{
                border:0.5px solid #c1c1c1;
            }

            .m-top-2 {
                margin-top: 2pt;
            }
            
            .m-top-4 {
                margin-top: 4pt;
            }
            
            .m-top-8 {
                margin-top: 8pt;
            }
            
            .grey-box {
                background-color: #d3d3d3;
                border:1px solid #000000;
            }
            .disclaimer {
                width: 80%;
                text-align: center;
                font-family: Sans-serif;
                font-size:10pt;
            }
            .leftColumn, .rightColumn {
                vertical-align: top; 
                width: 50%;
            }
            .p-top-10 {
                padding-top:4px;
            }
        </style>
    </head>
    <apex:pageMessages ></apex:pageMessages>
    
    <apex:variable var="invoiceIndex" value="{!1}" /> 
    <apex:repeat value="{!invoiceDatas}" var="data">
        <div style="{!if(invoiceIndex <= 1, 'page-break-before:avoid;','page-break-before:always;')}">
            <apex:variable var="invoiceIndex" value="{!invoiceIndex + 1}" />
        </div>
        <!-- FRONT SHEET -->
        <div class="header" style="height: 70px;">
            <table style="width: 100%; font-family:Sans-serif;">
                <tr>
                    <td style="width: 33.33%; text-align: left; vertical-align: top">
                        <apex:image width="250px" url="/sfc/servlet.shepherd/version/download/{!invoiceLogoMap[data.sfInvoice.tc9_et__Invoice_Entity__c]}" rendered="{!hasInvoiceLogoMap[data.sfInvoice.tc9_et__Invoice_Entity__c]}"/>
                    </td> 
                    <td style="width: 33.33%; text-align: left; vertical-align: top">
                        <div><h1>{!IF(OR(data.sfInvoice.RecordType.DeveloperName = 'Credit_Payroll_Items', data.sfInvoice.RecordType.DeveloperName = 'Credit_Invoiceable_Fees'), 'CREDIT NOTE', 'TAX INVOICE')}</h1></div>
                    </td>
                    <td style="width: 33.33%; text-align: left; vertical-align: top">
                    </td>
                </tr>
            </table>
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <br/>
            <div style="width:100%; border-top:1pt #D3D3D3 solid;"></div>
            <p style="float:left;font-size: 9pt;font-family: Sans-serif; margin-top:18pt">Invoice No: {!data.sfInvoice.Name}</p>
            <p class="pagenumber" style="float:right"/>
        </div>

        <!-- FRONT SHEET TABLE -->
        <div class="body">
            <div class="" style="font-size:9pt; page-break-inside:auto">
                <table style="width: 100%; font-family:Sans-serif;margin-top:20px;">
                    <tr>
                        <td style="vertical-align: top; text-align:center;" colspan="3">
                            
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 33.33%; text-align: left; vertical-align: top">
                            <div style="" class="text-header">ATTENTION: {!data.sfInvoice.tc9_et__Invoice_To_Contact__r.Name}</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_To_Account__r.Name}</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_To_Account__r.BillingStreet}</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_To_Account__r.BillingCity} {!data.sfInvoice.tc9_et__Invoice_To_Account__r.BillingState} {!data.sfInvoice.tc9_et__Invoice_To_Account__r.BillingPostalcode}</div>
                        </td>
                        <td style="width: 33.33%; text-align: left; vertical-align: top">
                            <div style="" class="text-body"><b>{!IF(OR(data.sfInvoice.RecordType.DeveloperName = 'Credit_Payroll_Items', data.sfInvoice.RecordType.DeveloperName = 'Credit_Invoiceable_Fees'), 'Credit No', 'Invoice No')}: {!data.sfInvoice.Name}</b></div>
                            <div style="margin-top:5px;" class="text-body"><b>Original Invoice: {!data.sfInvoice.tc9_et__Original_Invoice__r.Name}</b></div>
                            <div style="margin-top:5px;" class="text-body"><b>Invoice Date:&nbsp;
                                <apex:outputText value="{0, date,dd MMMM yyyy }">
                                    <apex:param value="{!data.sfInvoice.tc9_et__Invoice_Date__c}" />
                                </apex:outputText></b>
                            </div>
                            <div style="margin-top:5px;" class="text-body"><b>Invoice Period: {!data.InvoiceCalendarPeriodStartDate} - {!data.InvoiceCalendarPeriodEndDate}
                            </b></div>
                            <div style="margin-top:5px;" class="text-body"><b>Due Date:&nbsp;
                                <apex:outputText value="{0, date,dd MMMM yyyy }">
                                    <apex:param value="{!data.sfInvoice.tc9_et__Due_Date__c}" />
                                </apex:outputText></b>
                            </div>
                            <div style="margin-top:5px;" class="text-body"><b>Customer No:{!data.sfInvoice.tc9_et__Invoice_To_Account__r.Customer_ID__c}</b> </div>
                            <div style="margin-top:5px;" class="text-body"><b>Purchase Order: {!data.PurchaseOrderNumber}</b></div>
                        </td>
                        <td style="width: 33.33%; text-align: left; vertical-align: top">
                            <div style="" class="text-body">Invoice Enquiries</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_Entity__r.Trading_Name__c}</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_Entity__r.BillingStreet}</div>
                            <div style="margin-top:5px;" class="text-body">{!data.sfInvoice.tc9_et__Invoice_Entity__r.BillingCity} {!data.sfInvoice.tc9_et__Invoice_Entity__r.BillingState} {!data.sfInvoice.tc9_et__Invoice_Entity__r.BillingPostalcode}</div>
                            <div style="margin-top:10px;" class="text-body">ABN: {!data.sfInvoice.tc9_et__Invoice_Entity__r.tc9_pr__ABN__c}</div>
                            <div style="margin-top:5px;" class="text-body">P. {!data.sfInvoice.tc9_et__Invoice_Entity__r.Phone}</div>
                            <div style="margin-top:5px;" class="text-body">E. {!data.sfInvoice.tc9_et__Invoice_Entity__r.tc9_et__Send_Invoice_Emails_From_Email__c}</div>
                        </td>
                    </tr>
                </table>
                <table class="invoiceTable" style="page-break-inside:auto; width:100%; margin-top: 2em;" >
                    <thead >                                
                        <tr  class="invDetailTable">
                            <th style="width: 6%"> <apex:outputText styleClass="text-table-data" value="Date"/></th>
                            <th style=""> <apex:outputText styleClass="text-table-data" value="Name"/></th>
                            <th style=""> <apex:outputText styleClass="text-table-data" value="Ward/Site"/></th>
                            <!-- <th style=""> <apex:outputText styleClass="text-table-data" value="Authoriser"/></th> -->
                            <th style=""> <apex:outputText styleClass="text-table-data" value="Position Description"/></th>
                            <th style="width: 8%"> <apex:outputText styleClass="text-table-data" value="Time"/></th>
                            <th style="width: 6%"> <apex:outputText styleClass="text-table-data" value="Shift"/></th>
                            <th style="width: 5%; text-align: right"> <apex:outputText styleClass="text-table-data" value="Hours / Quantity"/></th>
                            <th style="width: 5%; text-align: right;"> <apex:outputText styleClass="text-table-data" value="Rate"/></th>
                            <th style="padding-left:5px;"> <apex:outputText styleClass="text-table-data" value="Type"/></th>
                            <th style="width: 7%; text-align: right"> <apex:outputText styleClass="text-table-data" value="Total"/></th>
                            <th style="width: 7%; text-align: right"> <apex:outputText styleClass="text-table-data" value="GST"/></th>
                            <th style="width: 10%; text-align: right"> <apex:outputText styleClass="text-table-data" value="Total inc GST"/></th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Frontpage invoice items display -->
                        <apex:variable var="invoiceItemIndex" value="{!1}" /> 
                        <apex:variable var="priorTime" value="" /> 
                        <apex:repeat var="group" value="{! data.ItemGroups }">
                            <tr style="display:{!IF(invoiceItemIndex == 1, 'none', '')}" class="totalBtmLightGreyLine"><td colspan="12" style="text-align: right;padding-top:4px;"></td></tr>

                            <tr style="page-break-inside:avoid; page-break-after:auto;padding-top:6pt;">
                                <td class="p-top-10" style="vertical-align: top">
                                    <apex:outputText value="{0, date,dd/MM/yyyy }">
                                        <apex:param value="{! group.FirstGroupItemLine.startDate }" />
                                    </apex:outputText>
                                </td>
                                <td class="p-top-10">{! group.FirstGroupItemLine.name }</td>
                                <td class="p-top-10">{! group.FirstGroupItemLine.facility }</td>
                                <!-- <td class="p-top-10">{! group.FirstGroupItemLine.authoriser }</td> -->
                                <td class="p-top-10">{! group.FirstGroupItemLine.positionDescription }</td>
                                <td class="p-top-10">{! group.FirstGroupItemLine.timeRange }</td>
                                <td class="p-top-10">{! group.FirstGroupItemLine.shift }</td>
                                <td class="p-top-10" style="text-align: right;">
                                    <apex:outputText value="{0, number,###,##0.00}">
                                        <apex:param value="{! group.FirstGroupItemLine.quantity }" />
                                    </apex:outputText>
                                </td>
                                <td class="p-top-10" style="text-align: right; ">
                                    <apex:outputText value="{0, number,###,##0.00}">
                                        <apex:param value="{! group.FirstGroupItemLine.rate }" />
                                    </apex:outputText>
                                </td>
                                <td class="p-top-10" style="padding-left:5px; vertical-align:top; padding-bottom: 4px;">
                                    <div>{! group.FirstGroupItemLine.type }</div>
                                    <apex:outputPanel rendered="{! NOT(ISBLANK(group.FirstGroupItemLine.timesheetActivityName)) }">
                                        <div style="padding-top: 4px;">
                                            {! group.FirstGroupItemLine.timesheetActivityName }
                                        </div>
                                    </apex:outputPanel>
                                
                                    <apex:outputPanel rendered="{! NOT(ISBLANK(group.FirstGroupItemLine.projectCodeName)) }">
                                        <div style="padding-top: 4px;">
                                            {! group.FirstGroupItemLine.projectCodeName }
                                        </div>
                                    </apex:outputPanel>
                                </td>
                                
                                <td class="p-top-10" style="text-align: right; ">
                                    <apex:outputText value="${0, number,###,##0.00}">
                                        <apex:param value="{! group.FirstGroupItemLine.total }" />
                                    </apex:outputText>
                                </td>
                                <td class="p-top-10" style="text-align: right; ">
                                    <apex:outputText value="${0, number,###,##0.00}">
                                        <apex:param value="{! group.FirstGroupItemLine.gst }" />
                                    </apex:outputText>
                                </td>
                                <td class="p-top-10" style="text-align: right; ">
                                    <apex:outputText value="${0, number,###,##0.00}">
                                        <apex:param value="{! group.FirstGroupItemLine.totalIncGST }" />
                                    </apex:outputText>
                                </td>
                                <apex:variable var="priorTime" value="{! group.FirstGroupItemLine.timeRange }" /> 
                            </tr>  
                        
                            <apex:repeat var="fgroup" value="{! group.FollowingGroupItemLines }">
                                <tr style="page-break-inside:avoid; page-break-after:auto;padding-top:6pt;">
                                    <apex:variable var="curTime" value="{! fgroup.timeRange }" /> 

                                    <apex:outputPanel layout="none" rendered="{!priorTime == curTime}">
                                        <td colspan="6"></td>
                                    </apex:outputPanel>

                                    <apex:outputPanel layout="none" rendered="{!priorTime != curTime}">
                                        <td colspan="4"></td>
                                        <td style="border-top:0.5pt solid #e6e6e6; padding-bottom: 4px;">{! fgroup.timeRange }</td>
                                        <td style="border-top:0.5pt solid #e6e6e6; padding-bottom: 4px;"></td>
                                    </apex:outputPanel>

                                    <td style="text-align: right; border-top:0.5pt solid #e6e6e6;">
                                        <apex:outputText value="{0, number,###,##0.00}">
                                            <apex:param value="{! fgroup.quantity }" />
                                        </apex:outputText>
                                    </td>
                                    <td style="text-align: right; border-top:0.5pt solid #e6e6e6;">
                                        <apex:outputText value="{0, number,###,##0.00}">
                                            <apex:param value="{! fgroup.rate }" />
                                        </apex:outputText>
                                    </td>
                                    <td style="padding-left:5px; border-top:0.5pt solid #e6e6e6; padding-bottom: 4px;">
                                        <div>{! fgroup.type }</div>
                                        <apex:outputPanel rendered="{! NOT(ISBLANK(fgroup.timesheetActivityName)) }">
                                            <div style="padding-top: 4px;">
                                                {! fgroup.timesheetActivityName }
                                            </div>
                                        </apex:outputPanel>
                                    
                                        <apex:outputPanel rendered="{! NOT(ISBLANK(fgroup.projectCodeName)) }">
                                            <div style="padding-top: 4px;">
                                                {! fgroup.projectCodeName }
                                            </div>
                                        </apex:outputPanel>
                                    </td>
                                    <td style="text-align: right; border-top:0.5pt solid #e6e6e6;">
                                        <apex:outputText value="${0, number,###,##0.00}">
                                            <apex:param value="{! fgroup.total }" />
                                        </apex:outputText>
                                    </td>
                                    <td style="text-align: right; border-top:0.5pt solid #e6e6e6;">
                                        <apex:outputText value="${0, number,###,##0.00}">
                                            <apex:param value="{! fgroup.gst }" />
                                        </apex:outputText>
                                    </td>
                                    <td style="text-align: right; border-top:0.5pt solid #e6e6e6;">
                                        <apex:outputText value="${0, number,###,##0.00}">
                                            <apex:param value="{! fgroup.totalIncGST }" />
                                        </apex:outputText>
                                    </td>
                                </tr>    
                                <apex:variable var="priorTime" value="{! fgroup.timeRange }" /> 
                            </apex:repeat>
                            <apex:variable var="invoiceItemIndex" value="{!invoiceItemIndex + 1}" />
                        </apex:repeat>

                        <tr class="totalBtmGreyLine"><td colspan="12" style="text-align: right;padding-top:12px;"></td></tr>
                        <tr style="page-break-inside:avoid; page-break-after:auto;padding-top:12px;">
                            <td colspan="3" style="text-align:left;padding-top:12px;"><b>Grand Totals</b></td>
                            <td colspan="6" style="padding-top:12px;"></td>
                            <td style="text-align: right;padding-top:12px;">
                                <apex:outputText value="${0, number,###,##0.00}">
                                    <apex:param value="{! data.sfInvoice.tc9_et__Invoice_Total_Ex_Tax__c }" />
                                </apex:outputText>
                            </td>
                            <td style="text-align: right;padding-top:12px;">
                                <apex:outputText value="${0, number,###,##0.00}">
                                    <apex:param value="{! data.sfInvoice.tc9_et__Invoice_Total_Tax__c }" />
                                </apex:outputText>
                            </td>
                            <td style="text-align: right;padding-top:12px;">
                                <apex:outputText value="${0, number,###,##0.00}">
                                    <apex:param value="{! data.sfInvoice.tc9_et__Invoice_Total_Inc_Tax__c }" />
                                </apex:outputText>
                            </td>
                        </tr>    
                                        
                    </tbody>
                </table>

                <br/> 
                <br/> 
                <div class="disclaimer" style="margin: auto;">
                    <p class="text-body">{!'EFT payments shouId be made to ' + data.sfInvoice.tc9_et__Invoice_Entity__r.Name}</p>
                    <p class="text-body">{!'BSB: ' + data.sfInvoice.tc9_et__Invoice_Entity__r.tc9_et__Bank_Account_Branch_Code__c + ' Account: ' + data.sfInvoice.tc9_et__Invoice_Entity__r.tc9_et__Bank_Account_Number__c}</p>
                    <p class="text-body">{!data.sfInvoice.tc9_et__Invoice_Message__c}</p>
                </div>
            </div>

            <!-- BACKING SHEET -->
            <apex:outputPanel rendered="{!IF(data.sfInvoice.tc9_et__Invoice_Setting__r.tc9_et__Include_Backing_Sheet__c == 'Yes', true,false)}" > 
                <apex:repeat var="timesheet" value="{! data.backingSheet.timesheets }">
                    <div style="page-break-before:always;">
    
                    </div>
                    <div class="header" style="height: 70px;">
                        <table style="width: 100%; font-family:Sans-serif;">
                            <tr>
                                <td style="width: 33.33%; text-align: left; vertical-align: top">
                                    <apex:image width="250px" url="/sfc/servlet.shepherd/version/download/{!invoiceLogoMap[data.sfInvoice.tc9_et__Invoice_Entity__c]}" rendered="{!hasInvoiceLogoMap[data.sfInvoice.tc9_et__Invoice_Entity__c]}"/>
                                </td> 
                            </tr>
                        </table>
                    </div>
                    <h2>Timesheet</h2>
                    <apex:panelGrid columns="2" width="100%" columnClasses="leftColumn,rightColumn" cellpadding="10">
                        <apex:outputPanel layout="block" >
                            <table style="width: 100%;">
                                <tr>
                                    <th style="width: 30%">Job Order :</th>
                                    <td>{!timesheet.sfTimesheet.tc9_et__Assignment__r.tc9_pr__Assignment_Name__c}</td>
                                </tr>
                                <tr>
                                    <th style="width: 30%" >Start Date :</th>
                                    <td>
                                        <apex:outputText value="{0, date,dd/MM/yyyy }">
                                            <apex:param value="{!timesheet.sfTimesheet.tc9_et__Start_Date__c}" />
                                        </apex:outputText>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="width: 30%">End Date :</th>
                                    <td>
                                        <apex:outputText value="{0, date,dd/MM/yyyy }">
                                            <apex:param value="{!timesheet.sfTimesheet.tc9_et__End_Date__c}" />
                                        </apex:outputText>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="width: 30%">Position :</th>
                                    <td>{!timesheet.TeamName}</td>
                                </tr>
                            </table>
                        </apex:outputPanel>
    
                        <apex:outputPanel layout="block" >
                            <table style="width: 100%;">
                                <tr>
                                    <th style="width: 35%">Payee Name :</th>
                                    <td>{!timesheet.sfTimesheet.tc9_et__Employee__r.Name}</td>
                                </tr>
                                <tr>
                                    <th style="width: 35%">Order by contact :</th>
                                    <td >{!data.sfInvoice.tc9_et__Invoice_To_Contact__r.Name}</td>
                                </tr>
                                <tr>
                                    <th style="width: 35%">Purchase Order No:</th>
                                    <td>{!data.PurchaseOrderNumber}</td>
