<html>
<head>
	<title></title>
</head>
<body style="height: auto; min-height: auto;">
<table border="0" cellpadding="0" cellspacing="0" style="background-color: #f6f6f6; padding: 10px;" width="100%">
	
		<tr>
			<td align="center" bgcolor="#f6f6f6">
			<table border="0" cellpadding="0" cellspacing="0" style="background-color:#ffffff; width: 600px;">
				
					<tr>
						<td style="padding: 0; background-color: #ffffff;"><img alt="Alliance Rural &amp; Remote - Email header (2)" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/Alliance_Rural_Remote_Email_heade?oid=00DAD00000BK4sL" style="max-width: 683.05px" title="Alliance Rural &amp; Remote - Email header (2)" /><a href="https://www.alliancenursing.com.au"> </a></td>
					</tr>
					<tr>
						<td style="height: 30px;">&nbsp;</td>
					</tr>
					<tr>
						<td align="left" style="padding: 0 45px;">
						<p style="font-size:18px;line-height:25px;color:#000000; font-weight: 400; font-family: 'Roboto', Arial, sans-serif; margin:10px 0 20px;"><br />
						Hi {{{Recipient.FirstName}}},&nbsp;<br />
						<br />
						&nbsp;</p>

						<table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; margin-top: 20px;">
							<thead>
								<tr>
									<th colspan="2" style="border: 1px solid #ddd; padding: 8px; text-align: left; background-color: #f4f4f4;">Candidate Submission Email Template Form</th>
								</tr>
							</thead>
							
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Date of Submission&nbsp;<i>(LHD/SHN to respond within 72 hours)</i></td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Supplying Agency Name</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Candidate’s Full Legal Name</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Candidate contact details: mobile number/email</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">AHPRA Number</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">If previous NSW Health employee, provide Stafflink number</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">
									<p>&nbsp;</p>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">NSW Working with Children Check (WWCC) Number or Application Number</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Classification</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Year&nbsp;Level&nbsp;<i><u>Note:</u></i><u>&nbsp;<i>Statement of Service details must be supplied</i></u></td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Experience/Speciality Type</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Facility Name</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">MM Level/td&gt;</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Start Date</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">End Date</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Is travel required? (Yes/No/Not applicable)</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">If yes, specify the mode of transport (Car, Bus, Train, Plane)</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Travelling From</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Returning To</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Additional Requests/Information: i.e. advise if travelling with partner, or pets, bringing a caravan. Please note that all additional requests are assessed by the LHD/SHN, and are granted on a case by case basis.</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
							
						</table>

						<table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; margin-top: 0px;">
							<thead>
								<tr>
									<th colspan="2" style="border: 1px solid #ddd; padding: 8px; text-align: left; background-color: #f4f4f4;">National Police Check (NPC):</th>
								</tr>
							</thead>
							
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">Candidate DOB</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">NPC Issue Date</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 30%; padding: 10px;">NPC Reference Number*</td>
									<td style="border: 1px solid #ddd; padding: 8px; width: 70%; padding: 10px;">&nbsp;</td>
								</tr>
							
						</table>

<table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; margin-top: 0px;">
							
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 100%; padding: 10px;">*Agency has assessed any identified criminal records and there is nothing in the person’s criminal record history preventing them from undertaking all the key responsibilities of the role as per the NSW Health policy directive.</td>
								</tr>
								<tr>
									<td style="border: 1px solid #ddd; padding: 8px; width: 100%; padding: 10px;">
									<p><b>Submission Checklist of attached documents:</b></p>

									<p>☐&nbsp;Resume</p>

									<p>☐ 1st Reference dated within 12 months, current or most recent direct line manager, and relevant to role</p>

									<p>☐ 2nd Reference dated within 12 months and relevant to role</p>

									<p>☐&nbsp;WWCC Certificate or the NSW WWCC Application Number</p>

									<p>☐ Relevant Training/Certification (e.g., TRIAGE, ALS)</p>

									<p>☐ Statement of Service details</p>
									</td>
								</tr>
							
						</table>

						<p style="font-family: Arial, sans-serif;font-size:18px;line-height:25px;color:#000000;margin:10px 0 20px;"><br />
						If you have any questions at all please call us on <a href="tel:1300034494">07 4998 5550</a>.<br />
						<br />
						Kind regards,<br />
						{{{Sender.Name}}}<br />
						Alliance Rural &amp; Remote Health</p>
						</td>
					</tr>
					<tr>
						<td style="height: 20px;">&nbsp;</td>
					</tr>
					<tr>
						<td style="padding: 35px 0px 10px 0px;"><img alt="Alliance-graphic-line" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/Alliancegraphicline?oid=00DAD00000BK4sL" style="max-width: 1623.55px" title="Alliance-graphic-line" /></td>
					</tr>
					<tr>
						<td style="padding: 26px 45px 40px 45px;font-size: 12px;line-height: 22px;color: #374250;">
						<table border="0" cellpadding="0" cellspacing="0" style="/* margin: 0 auto; */">
							
								<tr>
									<td style="padding-right: 32px" valign="middle"><a href="https://www.facebook.com/allianceruralremote" rel="noopener noreferrer"><img alt="fb" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/fb?oid=00DAD00000BK4sL" style="max-width: 1623.55px" title="fb" /></a></td>
									<td style="padding-right: 32px" valign="middle"><a href="https://www.linkedin.com/company/373910" rel="noopener noreferrer"><img alt="in" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/in?oid=00DAD00000BK4sL" style="max-width: 1623.55px" title="in" /></a></td>
									<td style="padding-right: 32px" valign="middle"><a href="https://www.instagram.com/allianceruralremote/" rel="noopener noreferrer"><img alt="is" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/is?oid=00DAD00000BK4sL" style="max-width: 1623.55px" title="is" /></a></td>
									<td valign="middle"><a href="https://www.youtube.com/channel/UCVvnStor2YEhu-sOfyJOvbw" rel="noopener noreferrer"><img alt="yt" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/yt?oid=00DAD00000BK4sL" style="max-width: 1623.55px" title="yt" /></a></td>
								</tr>
							
						</table>
						</td>
					</tr>
				
			</table>
			</td>
		</tr>
	
</table>
</body>
