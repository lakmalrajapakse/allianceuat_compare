									<td style="padding-right: 16px;"><img alt="fb" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/fb?oid=00DAD00000BK4sL" style="max-width: 683.05px" title="fb" /></td>
									<td style="padding-right: 16px;"><img alt="in" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/in?oid=00DAD00000BK4sL" style="max-width: 683.05px" title="in" /></td>
									<td style="padding-right: 16px;"><img alt="is" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/is?oid=00DAD00000BK4sL" style="max-width: 683.05px" title="is" /></td>
									<td><img alt="yt" src="https://allianceaustralia--uat.sandbox.file.force.com/file-asset-public/yt?oid=00DAD00000BK4sL" style="max-width: 683.05px" title="yt" /></td>
								</tr>
							
