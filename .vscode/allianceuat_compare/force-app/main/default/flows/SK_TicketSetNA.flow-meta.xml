    <assignments>
        <description>Updates the ticket&apos;s status to N/A now that the user has confirmed it should be.</description>
        <name>SK_UpdateStatusToNA</name>
        <label>Update Status to N/A</label>
        <locationX>50</locationX>
        <locationY>638</locationY>
        <assignmentItems>
            <assignToReference>SK_GetTicket.SK_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>N/A</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>SK_UpdateTicketToNA</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Determine whether the user did or did not confirm setting the ticket as N/A.</description>
        <name>SK_IsNAConfirmed</name>
        <label>Is NA Confirmed?</label>
        <locationX>314</locationX>
        <locationY>518</locationY>
        <defaultConnector>
            <targetReference>SK_Skipped</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>N/A was NOT Confirmed</defaultConnectorLabel>
        <rules>
            <name>SK_NAWasConfirmed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SK_ConfirmNA</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SK_UpdateStatusToNA</targetReference>
            </connector>
            <label>N/A was Confirmed</label>
        </rules>
    </decisions>
    <decisions>
        <description>Only pending tickets can be set as N/A.</description>
        <name>SK_IsTicketPending</name>
        <label>Is Ticket Pending?</label>
        <locationX>578</locationX>
        <locationY>278</locationY>
        <defaultConnector>
            <targetReference>SK_NotPendingInstructions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Ticket is NOT Pending</defaultConnectorLabel>
        <rules>
            <name>SK_TicketIsPending</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SK_GetTicket.SK_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SK_ConfirmTicketAsNA</targetReference>
            </connector>
            <label>Ticket is Pending</label>
        </rules>
    </decisions>
