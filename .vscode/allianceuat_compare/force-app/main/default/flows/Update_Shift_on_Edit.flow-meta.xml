    <description>ALN-508 - Added update to the unused payee record
ALN-527 - Update Payroll Time Type Logic to Support Billable Start ,End Times and Actual Start ,End Time
ALN-542/ALN-508 - Added Get Payee Allowance RT element to filter Cancellation Allowance by Timesheet Allowance Template record type only</description>
    <environments>Default</environments>
    <formulas>
        <name>ff_payroll_time_type</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(
        NOT(ISBLANK({!$Record.sirenum__Billable_Start_Time__c})), 
        NOT(ISBLANK({!$Record.sirenum__Billable_End_Time__c}))
    ),
    &quot;Billable&quot;,
    IF(
        AND(
            NOT(ISBLANK({!$Record.sirenum__Actual_Start_Time__c})),
            NOT(ISBLANK({!$Record.sirenum__Actual_End_Time__c}))
        ),
        &quot;Actual&quot;,
        &quot;Scheduled&quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>frm2c9CheckPass</name>
        <dataType>Boolean</dataType>
        <expression>IF(
AND(
NOT(ISBLANK({!$Record.sirenum__Site__r.sirenum__Timezone__c})),
NOT(ISBLANK({!$Record.sirenum__Contact__c})),
NOT(ISBLANK({!$Record.tc9_ext_sirint__Public_Holiday_Calendar__c})),
{!frmTimeCheck} = true,
OR(
AND(
ISPICKVAL({!$Record.sirenum__Team__r.tc9_ext_sirint__Inherit_Rate_Calculator_Values_From__c}, &quot;Assignment&quot;),
NOT(ISBLANK({!$Record.Minimum_Pay_Rate__c}))
),
ISPICKVAL({!$Record.sirenum__Team__r.tc9_ext_sirint__Inherit_Rate_Calculator_Values_From__c}, &quot;Rate Calculator Template&quot;))
),true, false)</expression>
    </formulas>
    <formulas>
        <name>frmAssignmentString</name>
        <dataType>String</dataType>
        <expression>{!$Record.sirenum__Team__r.Id} + &quot;_&quot; + {!$Record.sirenum__Contact__r.Id} + &quot;_&quot; + {!$Record.Minimum_Pay_Rate__c} + &quot;_&quot; + {!$Record.tc9_ext_sirint__Public_Holiday_Calendar__c}</expression>
    </formulas>
    <formulas>
        <name>frmScheduledJobProcessed</name>
        <dataType>Boolean</dataType>
        <expression>IF(
AND(
{!frm2c9CheckPass} = TRUE,
NOT(ISBLANK({!$Record.sirenum__Approved_By_Client__c}))
),true, false
)</expression>
    </formulas>
    <formulas>
        <name>frmTimeCheck</name>
        <dataType>Boolean</dataType>
        <expression>IF(
OR(
AND(
ISPICKVAL({!$Record.tc9_ext_sirint__Payroll_Time_Type__c}, &quot;Billable&quot;),
NOT(ISBLANK({!$Record.sirenum__Billable_Start_Time__c})),
NOT(ISBLANK({!$Record.sirenum__Billable_End_Time__c}))
),
AND(
ISPICKVAL({!$Record.tc9_ext_sirint__Payroll_Time_Type__c}, &quot;Scheduled&quot;),
NOT(ISBLANK({!$Record.sirenum__Scheduled_Start_Time__c})),
NOT(ISBLANK({!$Record.sirenum__Scheduled_End_Time__c}))
),
AND(
ISBLANK(TEXT({!$Record.tc9_ext_sirint__Payroll_Time_Type__c})),
NOT(ISBLANK({!$Record.sirenum__Scheduled_Start_Time__c})),
NOT(ISBLANK({!$Record.sirenum__Scheduled_End_Time__c}))
),
AND(
ISPICKVAL({!$Record.tc9_ext_sirint__Payroll_Time_Type__c}, &quot;Actual&quot;),
NOT(ISBLANK({!$Record.sirenum__Actual_Start_Time__c})),
NOT(ISBLANK({!$Record.sirenum__Actual_End_Time__c}))
)
),true,false)</expression>
    </formulas>
