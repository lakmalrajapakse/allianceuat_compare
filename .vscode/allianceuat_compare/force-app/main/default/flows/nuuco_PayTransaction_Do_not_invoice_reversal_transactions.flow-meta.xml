    <decisions>
        <name>Remove_from_Invoicing</name>
        <label>Remove from Invoicing?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Reversal_Not_Invoiced_DO_NOT_INVOICE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.tc9_util__Is_Reversed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.tc9_et__Invoice_Item__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Transaction_No_Invoice</targetReference>
            </connector>
            <label>Reversal &amp; Not Invoiced - DO NOT INVOICE</label>
        </rules>
        <rules>
            <name>Original_Transaction_Not_Invoiced_DO_NOT_INVOICE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.tc9_util__Is_Reversal__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.tc9_util__Original_Pay_Transaction__r.tc9_et__Invoice_Item__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Update_Transaction_No_Invoice</targetReference>
            </connector>
            <label>Original Transaction Not Invoiced - DO NOT INVOICE</label>
        </rules>
    </decisions>
