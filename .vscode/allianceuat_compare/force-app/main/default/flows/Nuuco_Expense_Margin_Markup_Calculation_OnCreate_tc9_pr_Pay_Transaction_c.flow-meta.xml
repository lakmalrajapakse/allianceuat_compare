    <description>ALN-35 Arran F
ALN-324 = Add in elements to calculate the margin/markup as per requirements and apply/update the invoice rate with it
ALN-324 = Fix margin/markup field references
ALN-324 = Amend picklist values after deployment</description>
    <environments>Default</environments>
    <formulas>
        <name>ff_BillRateMargin</name>
        <dataType>Number</dataType>
        <expression>{!$Record.tc9_pr__Pay_Rate__c} * (1 + {!$Record.tc9_pr__Client__r.Oncost_Margin__c} / 100)</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>ff_BillRateMarkup</name>
        <dataType>Number</dataType>
        <expression>{!$Record.tc9_pr__Pay_Rate__c} + {!$Record.tc9_pr__Client__r.Oncost_Markup__c}</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>ff_CERBillRateMargin</name>
        <dataType>Number</dataType>
        <expression>{!$Record.tc9_pr__Pay_Rate__c}*(1+{!Get_Matching_Expense_Rule.Amount__c}/100)</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>ff_CERBillRateMarkup</name>
        <dataType>Number</dataType>
        <expression>{!$Record.tc9_pr__Pay_Rate__c}+{!Get_Matching_Expense_Rule.Amount__c}</expression>
        <scale>6</scale>
    </formulas>
