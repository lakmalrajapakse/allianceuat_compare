    <formulas>
        <name>EndTime_AMPMND</name>
        <dataType>DateTime</dataType>
        <expression>IF(LEFT(TEXT({!$Record.sirenum__Type__c}), 2) &lt;&gt; &quot;ND&quot;,DATETIMEVALUE ({!$Record.sirenum__Local_Start_Date__c}) -{!$User.GMT_Offset__c}/24 + 

CASE( LEFT(TEXT({!$Record.sirenum__Type__c}), 2), 

    &quot;AM&quot;, 14/24, 

   &quot;PM&quot;, 22/24, 

    6/24), DATETIMEVALUE ({!$Record.sirenum__Local_Start_Date__c} + 1) - {!$User.GMT_Offset__c}/24 +6/24 )</expression>
    </formulas>
    <formulas>
        <name>StartTime_AMPMND</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Local_Start_Date__c}) 
- {!$User.GMT_Offset__c}/24 
+ CASE(LEFT(TEXT({!$Record.sirenum__Type__c}), 2),
       &quot;AM&quot;, 6/24, 
       &quot;PM&quot;, 14/24, 
       &quot;ND&quot;, 22/24, 
       0)</expression>
    </formulas>
