<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Evaluate_Shift_Length</name>
        <label>Evaluate Shift Length</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>X5_to_10_hours</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>10.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Meal_Break</targetReference>
            </connector>
            <label>5 to &lt;10 hours</label>
        </rules>
        <rules>
            <name>X10_or_more_hours</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>10.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_2_of_Create_Meal_Break</targetReference>
            </connector>
            <label>10 or more hours</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>FiveHourEndTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + (5 / 24) + (30 / 1440)</expression>
    </formulas>
    <formulas>
        <name>FiveHourMarkStartTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + (5 / 24)</expression>
    </formulas>
    <formulas>
        <name>MidpointEndTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + ({!Shift_Length_Hours} / 2) / 24 + (30 / 1440)</expression>
    </formulas>
    <formulas>
        <name>MidPointStartTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + ({!Shift_Length_Hours} / 2) / 24</expression>
    </formulas>
    <formulas>
        <name>Shift_Length_Hours</name>
        <dataType>Number</dataType>
        <expression>( DATETIMEVALUE({!$Record.sirenum__Scheduled_End_Time__c}) - DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) ) * 24</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>1218 - Shift Break Calculation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>1218 - Shift Break Calculation</label>
