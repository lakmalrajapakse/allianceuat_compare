    <screens>
        <description>Asks the user to select a job type from which to generate the required tickets.</description>
        <name>SK_GetJobType</name>
        <label>Get Job Type</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>SK_GetRequiredCompetenciesForTheJobTypeSelection</targetReference>
        </connector>
        <fields>
            <name>SK_JobTypeSelectInstructions</name>
            <fieldText>&lt;p&gt;Please tell us what type of job you are looking for and we will add the qualifications you need to your profile.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;You can only select one job type right now, but if you are interested in more you can repeat this process as many times as you like, choosing a different job type each time.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;We may need you to provide evidence that you hold a given qualification though we will make that clear when you submit a qualification for our review.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
