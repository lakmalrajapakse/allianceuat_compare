    <decisions>
        <name>Job_FFS_Daily</name>
        <label>Job FFS Daily or job FFS Weekly?</label>
        <locationX>314</locationX>
        <locationY>395</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>FFS_Daily</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Job.AA_Fee_for_Service_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Daily</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Job.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Fee_for_Service</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Closing_Report_Matching_Record_Type</targetReference>
            </connector>
            <label>FFS Daily</label>
        </rules>
        <rules>
            <name>FSS_Weekly</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Job.AA_Fee_for_Service_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Weekly</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Job.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Fee_for_Service</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_1_of_Get_Closing_Report_Matching_Record_Type</targetReference>
            </connector>
            <label>FSS Weekly</label>
        </rules>
    </decisions>
