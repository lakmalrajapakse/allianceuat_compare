<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Updates the Timesheet to be processed by the Cross-Assignment process.</description>
    <environments>Default</environments>
    <interviewLabel>Update Timesheet for Cross Assignment {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Timesheet for Cross Assignment</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Timesheet</name>
        <label>Update Timesheet</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>Cross_Assignment_Status__c</field>
            <value>
                <stringValue>Pending Insert</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>tc9_et__Transaction_Creation_Stage__c</field>
            <value>
                <stringValue>5</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Timesheet</targetReference>
        </connector>
        <filterFormula>AND(
ISPICKVAL({!$Record.tc9_et__Transaction_Creation_Stage__c}, &quot;2&quot;),
NOT(ISBLANK({!$Record.tc9_et__Assignment__r.Cross_Assignment_Group_By_ID__c})),
NOT(ISPICKVAL({!$Record.Cross_Assignment_Status__c}, &quot;Pending Delete&quot;))
)</filterFormula>
        <object>tc9_et__Timesheet__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
