    <decisions>
        <name>X2_week_roster</name>
        <label>2 week roster?</label>
        <locationX>182</locationX>
        <locationY>395</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_assignment.Interpretation_Period__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>2 week</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_TSE_to_2week_period</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>ff_2w_period_end_date</name>
        <dataType>Date</dataType>
        <expression>IF(
  {!ff_cycle} = 1, 
  {!get_assignment.First_2_week_period_start_date__c} + 13, 
  {!get_assignment.First_2_week_period_start_date__c} - 1 + (14 * {!ff_cycle})
)</expression>
    </formulas>
    <formulas>
        <name>ff_2w_period_start_date</name>
        <dataType>Date</dataType>
        <expression>IF(
  {!ff_cycle} = 1, 
  {!get_assignment.First_2_week_period_start_date__c}, 
  {!get_assignment.First_2_week_period_start_date__c} - 1 + (14 * {!ff_cycle}) - 13
)</expression>
    </formulas>
    <formulas>
        <name>ff_cycle</name>
        <dataType>Number</dataType>
        <expression>mceiling(({!$Record.tc9_et__Start_Date__c} - 
({!get_assignment.First_2_week_period_start_date__c-1}))/14)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>ff_unique_string</name>
        <dataType>String</dataType>
        <expression>{!$Record.tc9_et__Assignment__c} &amp; text({!ff_2w_period_start_date}) &amp; text({!ff_2w_period_end_date})</expression>
    </formulas>
    <interviewLabel>Timesheet Entry - Update period start/end dates for 2w cycle {!$Flow.CurrentDateTime}</interviewLabel>
