<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>ALN-464 - Created to stamp the Natural Account on the Invoice Item for the purposes of the Accounting Invoice Report</description>
    <environments>Default</environments>
    <interviewLabel>nuuco - Invoice Item - Set Natural Account on create {!$Flow.CurrentDateTime}</interviewLabel>
    <label>nuuco - Invoice Item - Set Natural Account on create</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>get_Invoice_Type</name>
        <label>get Invoice Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Update_Natural_Account</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>tc9_bgl__Accounting_System__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Setup.tc9_bgl__GL_Configuration__c.tc9_bgl__Default_Accounting_System_Setup_Id__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>tc9_bgl__Invoice_Item__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.tc9_et__Pay_Transaction__r.RecordType.Name</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>tc9_bgl__Acc_Invoice_Type__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Natural_Account</name>
        <label>Update Natural Account</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Natural_Account__c</field>
            <value>
                <elementReference>get_Invoice_Type.tc9_bgl__GL_Revenue_Account__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>get_Invoice_Type</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Natural_Account__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>tc9_et__Invoice_Item__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
