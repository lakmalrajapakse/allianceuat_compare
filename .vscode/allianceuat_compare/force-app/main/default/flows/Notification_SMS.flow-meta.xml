<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Notification triggered when SMS is received</description>
    <environments>Default</environments>
    <formulas>
        <name>MessageBody</name>
        <dataType>String</dataType>
        <expression>&apos;SMS Message Received from &apos; &amp; {!Get_Contact.Name}  &amp; &apos; of &apos;  &amp; {!Get_Contact.Branch_Name__c}  &amp; &apos; to &apos; &amp; {!Get_Cost_Center.Name} &amp; &apos;.&apos;</expression>
    </formulas>
    <interviewLabel>Notification - SMS {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Notification - SMS</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Contact</name>
        <label>Get Contact</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_SMS_Custom_Metadata</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Contact__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Contact</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>Branch__c</queriedFields>
        <queriedFields>Branch_Name__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Cost_Center</name>
        <label>Get Cost Center</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Send_Notification</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SMS_Cost_Center__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_SMS_Custom_Metadata.DeveloperName</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Cost_Center__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Needed to get Cost Center/Team.</description>
        <name>Get_SMS_Custom_Metadata</name>
        <label>Get SMS Custom Metadata</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Cost_Center</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Sender_Phone_Number__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Destination_Number__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Application_SMS_Configuration__mdt</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Contact</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Direction__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>inbound</stringValue>
            </value>
        </filters>
        <object>MobileMessaging_SMS_Message__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Send_Notification</name>
        <label>Send Notification</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>Notification_Sub_Flow</flowName>
        <inputAssignments>
            <name>Body</name>
            <value>
                <elementReference>MessageBody</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>Branch</name>
            <value>
                <elementReference>Get_Contact.Branch__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>Notification_Name</name>
            <value>
                <stringValue>SMS_Received</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>Target_Object_Id</name>
            <value>
                <elementReference>$Record.Contact__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>Team</name>
            <value>
                <elementReference>Get_Cost_Center.Team__c</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
