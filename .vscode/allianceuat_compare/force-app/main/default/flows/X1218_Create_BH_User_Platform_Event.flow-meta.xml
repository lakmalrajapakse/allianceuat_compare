    <decisions>
        <name>BH_Connect_User_creation_failed</name>
        <label>BH Connect User creation failed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Flow.FaultMessage</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Duplicate Username</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Flow.FaultMessage</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Username already exists</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_2_of_Assign_User_Fields</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>This flow triggers when an Application Sub Status record is created or updated to “BH Connect”. The flow validates whether a Salesforce User already exists for the related Contact. If no User exists, it initiates the BH Connect User creation process. This automation prevents duplicate User creation and ensures controlled onboarding into BH Connect.</description>
    <environments>Default</environments>
    <formulas>
        <name>alias</name>
        <dataType>String</dataType>
        <expression>LEFT({!Get_Conatct.FirstName}, 1) &amp; 
LEFT({!Get_Conatct.LastName}, 3)</expression>
    </formulas>
    <formulas>
        <name>allianceUsername</name>
        <dataType>String</dataType>
        <expression>&quot;alliance.&quot; &amp; {!Get_Conatct.Email}</expression>
    </formulas>
    <formulas>
        <name>ConvertCandidateTimezoneToUserTimeZone</name>
        <dataType>String</dataType>
        <expression>CASE(
  {!Get_Conatct.Candidate_Timezone__c},
  &quot;Australia/Melbourne&quot;, &quot;Australia/Melbourne&quot;,
  &quot;Australia/Sydney&quot;, &quot;Australia/Sydney&quot;,
  &quot;Australia/Brisbane&quot;, &quot;Australia/Brisbane&quot;,
  &quot;Australia/Perth&quot;, &quot;Australia/Perth&quot;,
  &quot;Australia/Adelaide&quot;, &quot;Australia/Adelaide&quot;,
  &quot;Australia/Hobart&quot;, &quot;Australia/Hobart&quot;,
  &quot;Australia/Broken_Hill&quot;, &quot;Australia/Broken_Hill&quot;,
  &quot;Australia/Currie&quot;, &quot;Australia/Currie&quot;,
  &quot;Australia/Darwin&quot;, &quot;Australia/Darwin&quot;,
  &quot;Australia/Eucla&quot;, &quot;Australia/Eucla&quot;,
  &quot;Australia/Lindeman&quot;, &quot;Australia/Lindeman&quot;,
  &quot;Australia/Lord_Howe&quot;, &quot;Australia/Lord_Howe&quot;,
  &quot;Indian/Christmas&quot;, &quot;Indian/Christmas&quot;,
  &quot;Indian/Cocos&quot;, &quot;Indian/Cocos&quot;,
  &quot;Pacific/Norfolk&quot;, &quot;Pacific/Norfolk&quot;,
  /* Default timezone if none match */
  &quot;Australia/Sydney&quot;
)</expression>
    </formulas>
