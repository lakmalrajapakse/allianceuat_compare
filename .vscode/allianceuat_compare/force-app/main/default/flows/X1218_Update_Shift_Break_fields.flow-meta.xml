    <decisions>
        <name>Evaluate_Shift_Length</name>
        <label>Evaluate Shift Length</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assignment_3</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default - Less than or equal to 5</defaultConnectorLabel>
        <rules>
            <name>X5_to_10_hours</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>10.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assignment_1</targetReference>
            </connector>
            <label>&gt; 5 and &lt;= 10 hours</label>
        </rules>
        <rules>
            <name>X10_or_more_hours</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Shift_Length_Hours</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>10.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assignment_2</targetReference>
            </connector>
            <label>More than 10</label>
        </rules>
    </decisions>
    <description>LO: Updating where the equal signs are used between different shift length parameters.

This flow is use to update the shift break fields on the shift creation and updating.</description>
    <environments>Default</environments>
    <formulas>
        <name>FiveHourEndTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + (5 / 24) + (30 / 1440)</expression>
    </formulas>
    <formulas>
        <name>FiveHourMarkStartTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + (5 / 24)</expression>
    </formulas>
    <formulas>
        <name>MidpointEndTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + ({!Shift_Length_Hours} / 2) / 24 + (30 / 1440)</expression>
    </formulas>
    <formulas>
        <name>MidPointStartTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) + ({!Shift_Length_Hours} / 2) / 24</expression>
    </formulas>
    <formulas>
        <name>SecondBreaklength</name>
        <dataType>Number</dataType>
        <expression> ({!FiveHourEndTime} - {!FiveHourMarkStartTime}) *24*60</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Shift_Length_Hours</name>
        <dataType>Number</dataType>
        <expression>( DATETIMEVALUE({!$Record.sirenum__Scheduled_End_Time__c}) - DATETIMEVALUE({!$Record.sirenum__Scheduled_Start_Time__c}) ) * 24</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>1218 - Update Shift Break fields {!$Flow.CurrentDateTime}</interviewLabel>
    <label>1218 - Update Shift Break fields</label>
