        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Loop_MPR</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <description>Loop the MPR&apos;s - this will give you the rates.  For each (where doesnt exist as an AR) create an  assignment rate with the pay rate = MPR pay rate and invoice rate = MPR.invoiceRate (where not null) OR MPR.PayRate and dates the same as MPR record.  

Also Use the same loop to get the Allowance pay code, and create a payee allowance record for the assignment.</description>
        <name>Loop_MPR</name>
        <label>Loop MPR</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_MPR_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Has_the_MPR_Pay_Code_already_been_created_in_Assignment_Rates</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_Missing_Assignment_Rates</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Related_Assignment_Rates</name>
        <label>Loop Related Assignment Rates</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Related_Assignment_Rates</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Is_the_Assignment_Rate_Pay_Code_Record_Type_equal_to_Allowance</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_Payee_Allowance_Records</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Related_Payee_Allowance_Records</name>
        <label>Loop Related Payee Allowance Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Related_Payee_Allowance_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Payee_Allowance_Record_Pay_Code_to_ExistingPayCodeIds</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Loop_Related_Assignment_Rates</targetReference>
        </noMoreValuesConnector>
    </loops>
