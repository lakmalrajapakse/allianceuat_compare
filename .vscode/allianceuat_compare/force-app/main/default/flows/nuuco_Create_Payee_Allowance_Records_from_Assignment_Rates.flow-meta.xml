    <description>ALN-332 - created</description>
    <environments>Default</environments>
    <interviewLabel>nuuco - Create Assignment Rates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>nuuco - Create Payee Allowance Records from Assignment Rates</label>
    <loops>
        <name>Loop_Existing_Assignment_Rates</name>
        <label>Loop Existing Assignment Rates</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Existing_Assignment_Rates</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
