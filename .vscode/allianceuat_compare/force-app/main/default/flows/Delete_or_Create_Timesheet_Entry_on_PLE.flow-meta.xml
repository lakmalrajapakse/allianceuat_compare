<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>52.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Approved_or_Recalled</name>
        <label>Approved or Recalled</label>
        <locationX>169</locationX>
        <locationY>352</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.tc9_pr__Approval_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_TSE</targetReference>
            </connector>
            <label>Approved</label>
        </rules>
        <rules>
            <name>Recalled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.tc9_pr__Approval_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Recalled</stringValue>
                </rightValue>
            </conditions>
            <label>Recalled</label>
        </rules>
    </decisions>
    <description>Delete Timesheet Entries or Recreate them based on PLE approval / recall.</description>
    <formulas>
        <name>ff_earlier_date</name>
        <dataType>Date</dataType>
        <expression>{!$Record.tc9_pr__Start_Date__c} -14</expression>
    </formulas>
    <formulas>
        <name>ff_later_date</name>
        <dataType>Date</dataType>
        <expression>{!$Record.tc9_pr__End_Date__c}+14</expression>
    </formulas>
    <formulas>
        <name>ff_PLE_Days</name>
        <dataType>Number</dataType>
        <expression>{!$Record.tc9_pr__End_Date__c} - {!$Record.tc9_pr__Start_Date__c}</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Delete Timesheet Entry on PLE Approval {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Delete or Create Timesheet Entry on PLE</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordDeletes>
        <name>Delete_TSE</name>
        <label>Delete TSE</label>
        <locationX>180</locationX>
        <locationY>563</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>tc9_et__Assignment__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.tc9_pr__Assignment__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>tc9_et__Start_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>$Record.tc9_pr__Start_Date__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>tc9_et__Start_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>$Record.tc9_pr__End_Date__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>tc9_et__Approval_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>New</stringValue>
            </value>
        </filters>
        <object>tc9_et__Timesheet_Entry__c</object>
    </recordDeletes>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Approved_or_Recalled</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>(1 OR 2) AND 3 AND 4</filterLogic>
        <filters>
            <field>tc9_pr__Approval_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </filters>
        <filters>
            <field>tc9_pr__Approval_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Recalled</stringValue>
            </value>
        </filters>
        <filters>
            <field>tc9_pr__Skip_Manager_Approval__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>No</stringValue>
            </value>
        </filters>
        <filters>
            <field>tc9_pr__Void__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>tc9_pr__Payee_Leave_Event__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>rec_Timesheet_Entry</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>tc9_et__Timesheet_Entry__c</objectType>
    </variables>
    <variables>
        <name>var_day_count</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
</Flow>
