    <description>Sends a Reminder email to the Candidate 24 hours before the Booking Start Time.
Added generic sender email 02/05/2025
Added the dynamic branch logic using the sub flow to sent the reminder as per the correct brand 11/11/25</description>
    <environments>Default</environments>
    <formulas>
        <name>booking_time_elapsed</name>
        <dataType>Number</dataType>
        <expression>({!$Record.b3o__Booking_Start_Time__c}-{!$Record.Booked_Timestamp__c})*24</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Hoursbeforeinterview</name>
        <dataType>Number</dataType>
        <expression>NOW() - DATETIMEVALUE ( {!$Record.b3o__Booking_Start_Time__c})</expression>
        <scale>2</scale>
    </formulas>
