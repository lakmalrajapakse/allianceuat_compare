    <decisions>
        <name>Actual_Times_Changed</name>
        <label>Actual Times Changed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Set_Payroll_Time_to_Actual</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.sirenum__Actual_Start_Time__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.sirenum__Actual_End_Time__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.tc9_ext_sirint__Payroll_Time_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scheduled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Payroll_Time_Type_to_Actual</targetReference>
            </connector>
            <label>Yes - Set Payroll Time to Actual</label>
        </rules>
    </decisions>
    <description>ALN-489 - Created to set the Payroll Time type to Actual where actual time worked</description>
    <environments>Default</environments>
    <interviewLabel>nuuco - Shift - Set Payroll to Actual Times when populated {!$Flow.CurrentDateTime}</interviewLabel>
    <label>nuuco - Shift - Set Payroll to Actual Times when populated</label>
