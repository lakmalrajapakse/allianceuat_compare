    <decisions>
        <description>Checks if the Job is already filled to see if processing needs to continue.</description>
        <name>Check_if_Job_is_filled</name>
        <label>Check If Job is Filled</label>
        <locationX>512</locationX>
        <locationY>674</locationY>
        <defaultConnector>
            <targetReference>Assign_Demand_Id</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Job is not filled</defaultConnectorLabel>
        <rules>
            <name>Job_is_filled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Job.s5m__BH4SFFillRateByClosingReports__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>100.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Job_Filled_Error_Screen</targetReference>
            </connector>
            <label>Job is filled</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the Job is current, not cancelled, and not closed.</description>
        <name>Check_if_Job_is_valid</name>
        <label>Check if Job is valid</label>
        <locationX>281</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Check_if_Job_is_filled</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Job is valid</defaultConnectorLabel>
        <rules>
            <name>Job_is_not_valid</name>
            <conditionLogic>1 OR 2 OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>Get_Job.s5m__Cancelled__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Job.TR1__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Job.TR1__Estimated_End_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Job.TR1__Estimated_End_Date__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Invalid_Job_Error_Screen</targetReference>
            </connector>
            <label>Job is not valid</label>
        </rules>
    </decisions>
    <decisions>
        <description>Checks if the Job has enough openings for the number of workers selected.</description>
        <name>Does_Job_Have_Openings</name>
        <label>Does Job Have Openings</label>
        <locationX>710</locationX>
        <locationY>1214</locationY>
        <defaultConnector>
            <targetReference>No_Openings_Error_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Job Doesn&apos;t have Openings</defaultConnectorLabel>
        <rules>
            <name>Job_Has_Openings</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>numberOfSelectedWorkerIds</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>numberOfOpenings</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Closing_Reports</targetReference>
            </connector>
            <label>Job Has Openings</label>
        </rules>
    </decisions>
    <description>Allows the worker search to be run against the given Job and lets the user create a closing report for given workers.</description>
    <environments>Default</environments>
    <formulas>
        <description>The formatted text of the selected value of the Highest Severity Broken picklist, provided to the Find Workers component.</description>
        <name>maxSeverity</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!HighestSeverityBroken}, &quot;NONE&quot;)</expression>
    </formulas>
    <formulas>
        <description>The number of openings on the Job.</description>
        <name>numberOfOpenings</name>
        <dataType>Number</dataType>
        <expression>{!Get_Job.TR1__Number_of_Openings__c} - {!Get_Job.s5m__BH4SFNumberOfClosingReports__c}</expression>
        <scale>2</scale>
    </formulas>
