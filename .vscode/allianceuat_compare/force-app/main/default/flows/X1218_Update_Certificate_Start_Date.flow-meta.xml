            </connector>
            <label>Start Date isRequired.</label>
        </rules>
        <rules>
            <name>End_Date_isRequired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.b3o__Certificate_Type__r.b3o__Require_End_Date__c</leftValueReference>
