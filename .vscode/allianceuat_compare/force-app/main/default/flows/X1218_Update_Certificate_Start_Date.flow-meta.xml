    <decisions>
        <name>Check_StartDate_or_End_Date_isRequired_in_Certificate_Type</name>
        <label>Check StartDate or End Date isRequired in Certificate Type?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Both_Start_Date_and_End_Date_isRequired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.b3o__Certificate_Type__r.b3o__Require_Start_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.b3o__Certificate_Type__r.b3o__Require_End_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Both_Start_Date_and_End_Date_Value</targetReference>
            </connector>
            <label>Both Start Date and End Date isRequired.</label>
        </rules>
        <rules>
            <name>Start_Date_isRequired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.b3o__Certificate_Type__r.b3o__Require_Start_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
