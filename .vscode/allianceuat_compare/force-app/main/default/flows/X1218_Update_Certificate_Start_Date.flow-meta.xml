                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_End_Date_Value</targetReference>
            </connector>
            <label>End Date isRequired.</label>
        </rules>
    </decisions>
    <description>This Flow is used to update the Start Date or End Date field of the Certificate if Certificate Type Require Start Date or End Date field is checked.</description>
    <environments>Default</environments>
    <formulas>
        <name>aYrFromToday</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 365</expression>
    </formulas>
